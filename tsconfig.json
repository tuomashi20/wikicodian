{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "CommonJS",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "importHelpers": false,
    "isolatedModules": true,
    "strict": false,
    "lib": ["DOM", "ESNext"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
